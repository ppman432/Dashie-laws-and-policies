            }
            
            instantTextBoxType = {
                name      = "war_exhaustion_value"
                position  = { x = 31 y = 4 }
                font      = "hoi_18mbs"
                text      = "war_exhaustion_value"
                format    = center
                maxWidth  = 40
                maxHeight = 23
                fixedsize = yes

                pdx_tooltip = "war_exhaustion_tab"
