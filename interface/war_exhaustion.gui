guiTypes = {

    containerWindowType = {
        name = "war_exhaustion_container"
        position = { x = 0 y = 0 }
		size = { width = 102%% height = 107%% } # not 100% so it can reach the edges... not sure why it works like this; could just be me?
        
        # Need to put the stuff in a subcontainer or else the area in which it can be moved around is severely limited; idk why
        containerWindowType = {
            name     = "war_exhaustion_container_2"
            position = { x = 320 y = 14 } # to the right of the nukes # (487, 30) for right under the fuel section
            size     = { width = 70 height = 26 }
            moveable = yes
            
            background = {
                name = "background"
                spriteType = "GFX_generic_box_small"
                alwaystransparent = no
            }
            
            iconType = {
                name = "war_exhaustion_icon"
